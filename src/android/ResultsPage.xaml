<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RD_AAOW.ResultsPage">

	<!-- Раздел ввода значений -->
	<ScrollView>
		<StackLayout>

			<Button x:Name="ScoreField" />

			<BoxView VerticalOptions="Center" HorizontalOptions="Center" HeightRequest="1" 
				WidthRequest="200" Color="#505050" Margin="12" />

			<Button x:Name="AchievementField" />

			<Label />

		</StackLayout>
	</ScrollView>
</ContentPage>
